            {
              "atomType": "GitHubMolecule",
              "x": 0.4713919726729291,
              "y": 0.2080745341614907,
              "uniqueID": "id-534",
              "name": "Solid-rod-bent-corner",
              "ioValues": [
                {
                  "name": "Tube_radius",
                  "ioValue": 0.125,
                  "currentEquation": "Hole_diam/2"
                },
                {
                  "name": "Bend_radius",
                  "ioValue": 0.5
                }
              ],
              "topLevel": false,
              "allAtoms": [
                {
                  "atomType": "Output",
                  "x": 0.98,
                  "y": 0.5,
                  "uniqueID": "id-530",
                  "ioValues": [
                    {
